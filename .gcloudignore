# Keep Cloud Build uploads aligned with the Docker build contexts.
*

!.dockerignore
!deploy/
!deploy/**
!nuvelle_api/
!nuvelle_api/**
!nuvelle_kit/
!nuvelle_kit/**
!nuvelle_website/
!nuvelle_website/out/
!nuvelle_website/out/**
!nuvelle_mobile/
!nuvelle_mobile/dist/
!nuvelle_mobile/dist/**
!nuvelle_web/
!nuvelle_web/dist/
!nuvelle_web/dist/**
!nuvelle_admin/
!nuvelle_admin/dist/
!nuvelle_admin/dist/**

**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.venv/
**/venv/

nuvelle_kit/out/
nuvelle_kit/_work/
nuvelle_kit/_uploads/
nuvelle_kit/_vidcache/
nuvelle_kit/fonts/
