{
  "name": "nuvelle",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev:website": "pnpm --filter nuvelle_website dev",
    "dev:mobile": "pnpm --filter nuvelle_mobile dev",
    "dev:web": "pnpm --filter nuvelle_web dev",
    "dev:admin": "pnpm --filter nuvelle_admin dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test --run",
    "deploy": "bash deploy/google-cloud.sh",
    "deploy:api": "ONLY=api bash deploy/google-cloud.sh",
    "deploy:frontend": "ONLY=frontend bash deploy/google-cloud.sh",
    "deploy:website": "ONLY=website bash deploy/google-cloud.sh",
    "deploy:mobile": "ONLY=mobile bash deploy/google-cloud.sh",
    "deploy:web": "ONLY=web bash deploy/google-cloud.sh",
    "deploy:admin": "ONLY=admin bash deploy/google-cloud.sh",
    "deploy:static": "ONLY=static bash deploy/google-cloud.sh",
    "deploy:verify": "ONLY=verify bash deploy/google-cloud.sh",
    "deploy:domain": "ONLY=domain bash deploy/google-cloud.sh",
    "deploy:help": "ONLY=help bash deploy/google-cloud.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
