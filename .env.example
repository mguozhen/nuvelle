# OpenAI-compatible router key used by the promo pipeline's AI calls (cover-frame pick + copy)
FLATKEY_API_KEY=sk-your-key-here
# optional override of the router base URL
# FLATKEY_BASE=https://router.flatkey.ai

# Public website blog integration. Store the real AccessKey outside git.
BLOGGER_API_URL=https://blogger-api-5qjldqffdq-uc.a.run.app
BLOGGER_ACCESS_KEY=blog_sk-your-access-key
BLOGGER_SITE_SLUG=nuvelle
BLOGGER_LANGUAGE=en
# Optional Blogger site language overrides. Nuvelle's Blogger site currently uses
# en/cn/jp/de/fr/es/pt, matching the public route locale keys.
# BLOGGER_LANGUAGE_CN=cn
# BLOGGER_LANGUAGE_JP=jp
BLOG_PAGE_SIZE=12
NEXT_PUBLIC_SITE_ORIGIN=https://nuvelle.ai
# Meta Pixel/Dataset ID for website traffic and content/lead events.
# Do not put Conversions API access tokens in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_META_PIXEL_ID=4457720874494573

# FastAPI + PostgreSQL local development
API_PORT=8000
DATABASE_URL=postgresql+psycopg://nuvelle:nuvelle_dev_password@localhost:5432/nuvelle
POSTGRES_DB=nuvelle
POSTGRES_USER=nuvelle
POSTGRES_PASSWORD=nuvelle_dev_password
POSTGRES_PORT=5432

# Optional image overrides for networks where Docker Hub is slow or unreachable.
# POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
# PYTHON_IMAGE=docker.1ms.run/library/python:3.11-slim
