# OpenAI-compatible router key used by the promo pipeline's AI calls (cover-frame pick + copy)
FLATKEY_API_KEY=sk-your-key-here
# optional override of the router base URL
# FLATKEY_BASE=https://router.flatkey.ai

# FastAPI + PostgreSQL local development
API_PORT=8000
DATABASE_URL=postgresql+psycopg://nuvelle:nuvelle_dev_password@localhost:5432/nuvelle
POSTGRES_DB=nuvelle
POSTGRES_USER=nuvelle
POSTGRES_PASSWORD=nuvelle_dev_password
POSTGRES_PORT=5432

# Optional image overrides for networks where Docker Hub is slow or unreachable.
# POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
# PYTHON_IMAGE=docker.1ms.run/library/python:3.11-slim
